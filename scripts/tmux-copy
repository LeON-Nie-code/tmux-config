#!/usr/bin/env sh
set -eu

if command -v pbcopy >/dev/null 2>&1; then
  exec pbcopy
fi

if command -v wl-copy >/dev/null 2>&1; then
  exec wl-copy
fi

if command -v xclip >/dev/null 2>&1; then
  exec xclip -selection clipboard -in
fi

if command -v xsel >/dev/null 2>&1; then
  exec xsel --clipboard --input
fi

tmp_file="${TMPDIR:-/tmp}/tmux-copy.$$"
cat > "$tmp_file"
printf 'tmux-copy: no clipboard command found. Install pbcopy, wl-copy, xclip, or xsel. Saved selection to %s\n' "$tmp_file" >&2
